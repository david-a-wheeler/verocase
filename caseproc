def parse_args() -> argparse.Namespace:
    """Build the argument parser, define all flags, and parse the command line."""
    parser = argparse.ArgumentParser(
        prog='caseproc',
        description='Process LTAC assurance-case files and inject rendered'
                    ' views into Markdown/HTML documents.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Selectors (--select TYPE [ID | *]):
  ltac/markdown  ID|*   render as an indented Markdown bullet list
  ltac/html      ID|*   render as a nested HTML list
  sacm/mermaid   ID|*   render as a SACM Mermaid flowchart
  gsn/mermaid    ID|*   render as a GSN Mermaid flowchart
  statement      ID     one-line statement for an element
  references     ID     Markdown links to packages that reference the element
  info           ID     statement followed by references
  Omit ID to use the element set by the nearest preceding header (filter mode).
  Use * to render all packages (ltac/*, sacm/mermaid, and gsn/mermaid only).

In documents, use <!-- caseproc SELECTOR --> ... <!-- end caseproc -->
to surround where these go.

Validations on the LTAC file (always):
  - Claim/Strategy must not appear under Evidence, Context, or Assumption
  - Each identifier must be declared (no ^ prefix) exactly once
  - Statement text must be consistent across all uses of the same identifier
  - SACM assertion status must be unambiguous (spec section 11)
  - Cited identifiers (^ID) must have a matching declaration
  - Explicit citation packages (^[PkgName] ID): package must declare ID

Additional checks when document files are provided:
  - Headers matching "TYPE ID" or "TYPE ID: statement" are cross-checked:
    unknown ID (not in LTAC) is flagged. Mismatched statement text are
    flagged (if "update" is false) or updated (if "update" is true).
  - Every declared LTAC element must have a corresponding document header
    (else they are flagged)

Configuration keys (--config FILE, JSON object):
  base_url           base URL for hyperlinks in sacm/mermaid output (default: "")
  markdown_base_url  base URL for hyperlinks in ltac/markdown and ltac/html output (default: "")
  pkg_label          word used to identify packages in headers and output (default: "Package ")
  pkg_header_prefix  string prepended to each package header when rendering * (default: "### ")
  pkg_header_suffix  string appended after each package header when rendering * (default: newline)
  update             if true, rewrite stale headers instead of warning (default: false)

For full details see docs/design-spec.md.""",
    )
    parser.add_argument(
        '--config', type=str, metavar='FILE',
        help='path to a JSON file containing configuration key/value pairs',
    )
    parser.add_argument(
        '--error', action='store_true',
        help='treat warnings as errors (non-zero exit on any warning)',
    )
    parser.add_argument(
        '--update', action='store_true',
        help='update document headers whose statement differs from the LTAC',
    )
    parser.add_argument(
        '--ltac', '-l', type=str, metavar='FILENAME',
        help='LTAC file to load (default: case.ltac or docs/case.ltac)',
    )
    parser.add_argument(
        'files', nargs='*',
        help='Markdown/HTML files to process (default: stdin)',
    )

    mode = parser.add_mutually_exclusive_group()
    mode.add_argument(
        '--validate', action='store_true',
        help='validate and report warnings/errors; do not produce output',
    )
    mode.add_argument(
        '--select', '-s', type=str, metavar='SELECTOR',
        help='render SELECTOR to stdout and exit (see selector table below)',
    )
    mode.add_argument(
        '--inline', '-i', action='store_true',
        help='rewrite each file in place with updated marked regions',
    )
    mode.add_argument(
        '--selftest', action='store_true',
        help='run the built-in doctest suite and exit (0 = all pass, 1 = any fail)',
    )

    return parser.parse_args()


def find_ltac_file(ltac_arg: Optional[str]) -> str:
    """Determine the path of the LTAC file to load.

    If --ltac was given, use that path directly.
    Otherwise try case.ltac in the current directory, then docs/case.ltac.
    Calls panic() (and exits) if no file can be found.
    """
    if ltac_arg:
        return ltac_arg
    if os.path.exists('case.ltac'):
        return 'case.ltac'
    if os.path.exists('docs/case.ltac'):
        return 'docs/case.ltac'
    panic("no LTAC file found; use --ltac or create case.ltac")


# SACM spec section 11 defines AssertionStatus as a mutually exclusive
# enumeration: Asserted (default), NeedsSupport, Assumed, Axiomatic, Defeated,
# AsCited.  An Assumption node implicitly carries Assumed; a cross-citation
# (^[PkgName]) implicitly carries AsCited.
def check_assertion_status(registry: Dict[str, Node]) -> None:
    """Error if any node carries more than one SACM assertion status.

    SACM spec section 11 defines AssertionStatus as a mutually exclusive
    enumeration with six values: Asserted (default, no option needed),
    NeedsSupport, Assumed, Axiomatic, Defeated, AsCited.
    """
    for node in registry.values():
        active = []
        if node.node_type == 'Assumption' or 'assumed' in node.options:
            active.append('Assumed')
        if 'needssupport' in node.options:
            active.append('NeedsSupport')
        if 'axiomatic' in node.options:
            active.append('Axiomatic')
        if 'defeated' in node.options:
            active.append('Defeated')
        if node.is_cited:
            active.append('AsCited')
        if len(active) >= 2:
            label = node.identifier or f'(unnamed {node.node_type})'
            error(f"{label}: conflicting assertion status: {', '.join(active)}"
                  f" (SACM spec section 11: Asserted/NeedsSupport/Assumed/"
                  f"Axiomatic/Defeated/AsCited are mutually exclusive)")


def check_id_info(id_info: Dict[str, dict], all_roots: List[Node],
                  pkg_label: str = DEFAULT_CONFIG['pkg_label']) -> None:
    """Validate identifier usage across the loaded LTAC.

    Uses the id_info table built during parsing (see LTACParser) to report:
    - IDs cited (^) but never declared (may indicate a missing package)
    - Explicit citation packages (^[PkgName]) that are not loaded
    - Explicit citation packages where the ID is not declared in that package
    """
    pkg_root_ids = {root.identifier for root in all_roots if root.identifier}
    for ident, info in id_info.items():
        if info['citations'] > 0 and info['declarations'] == 0:
            warn(f"{ident}: cited but never declared")
        for pkg in sorted(info['cited_pkgs']):
            if pkg not in pkg_root_ids:
                warn(f"{ident}: cited package {pkg!r} not found in loaded LTAC")
            elif info['decl_pkg_id'] is not None and info['decl_pkg_id'] != pkg:
                warn(f"{ident}: cited as belonging to '{pkg_label}{pkg}'"
                     f" but declared in '{pkg_label}{info['decl_pkg_id']}'")


def _process_files(
    files: List[str],
    out,
    registry: Dict[str, Node],
    all_roots: List[Node],
    config: dict,
    id_info: Dict[str, dict],
    seen_headers: set,
) -> None:
    """Open each file and call process_document_stream; fall back to stdin if none given."""
    if files:
        for path in files:
            try:
                with open(path) as f:
                    process_document_stream(f, out, registry, all_roots, config, id_info, seen_headers)
            except OSError as e:
                error(f"cannot open {path!r}: {e}")
    else:
        process_document_stream(sys.stdin, out, registry, all_roots, config, id_info, seen_headers)


def _check_header_coverage(registry: Dict[str, Node], seen_headers: set) -> None:
    """Warn about every registry element with no corresponding Markdown header."""
    for ident in registry:
        if ident not in seen_headers:
            warn(f"element {ident} has no corresponding header in any processed file")


def _inline_rewrite_file(
    path: str,
    registry: Dict[str, Node],
    all_roots: List[Node],
    config: dict,
    id_info: Dict[str, dict],
    seen_headers: set,
) -> None:
    """Process a single file in --inline mode, rewriting it atomically if content changed.

    Reads the file, renders all ltac regions, and writes back only if the content
    differs.  Leaves the file unchanged if any processing errors occur.
    """
    global _had_error
    error_before = _had_error
    try:
        with open(path) as f:
            original = f.read()
    except OSError as e:
        error(f"cannot open {path!r}: {e}")
        return
    buf = io.StringIO()
    with io.StringIO(original) as src:
        process_document_stream(src, buf, registry, all_roots, config, id_info, seen_headers)
    if _had_error and not error_before:
        # Errors occurred while processing this file; leave it untouched.
        return
    new_content = buf.getvalue()
    if new_content == original:
        return  # No change; skip the write.
    dir_ = os.path.dirname(os.path.abspath(path))
    try:
        fd, tmp = tempfile.mkstemp(dir=dir_)
        try:
            with os.fdopen(fd, 'w') as tf:
                tf.write(new_content)
            os.replace(tmp, path)
        except Exception:
            try:
                os.unlink(tmp)
            except OSError:
                pass
            raise
    except OSError as e:
        error(f"cannot write {path!r}: {e}")


def run_selftests() -> None:
    """Run all doctests embedded in this module and exit.

    Exits with code 0 if every test passes, 1 if any fail.
    Failed tests are shown with ndiff output so differences are easy to spot.
    """
    import doctest
    failures, _ = doctest.testmod(optionflags=doctest.REPORT_NDIFF)
    sys.exit(0 if failures == 0 else 1)


def main() -> None:
    """Entry point: parse arguments, load configuration and LTAC data, then dispatch."""
    global _strict

    args = parse_args()

    if args.selftest:
        run_selftests()
        return  # run_selftests() calls sys.exit(); this is a safety net

    if args.error:
        _strict = True

    config = load_config(args.config)
    if args.update:
        config['update'] = True

    all_roots: List[Node] = []
    registry: Dict[str, Node] = {}
    id_info: Dict[str, dict] = {}

    ltac_path = find_ltac_file(args.ltac)
    load_ltac_file(ltac_path, all_roots, registry, id_info)

    check_assertion_status(registry)
    check_id_info(id_info, all_roots, config.get('pkg_label', 'Package '))

    if args.select:
        result = render_selector(args.select, registry, all_roots, config, id_info)
        if result:
            print(result)
    elif args.validate:
        if args.files:
            _process_files(args.files, io.StringIO(), registry, all_roots, config, id_info, set())
    elif args.inline:
        seen_headers: set = set()
        for path in args.files:
            _inline_rewrite_file(path, registry, all_roots, config, id_info, seen_headers)
        _check_header_coverage(registry, seen_headers)
    else:
        seen_headers: set = set()
        _process_files(args.files, sys.stdout, registry, all_roots, config, id_info, seen_headers)
        _check_header_coverage(registry, seen_headers)

    if _had_error:
        sys.exit(1)


if __name__ == '__main__':
    main()
